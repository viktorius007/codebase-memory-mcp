    tests/repro/repro_lsp_java_cs.c \
    tests/repro/repro_lsp_kt_php_rust.c

ALL_TEST_SRCS =$(TEST_MAIN_SRC) $(TEST_FOUNDATION_SRCS) $(TEST_EXTRACTION_SRCS) $(TEST_STORE_SRCS) $(TEST_CYPHER_SRCS) $(TEST_MCP_SRCS) $(TEST_DISCOVER_SRCS) $(TEST_GRAPH_BUFFER_SRCS) $(TEST_PIPELINE_SRCS) $(TEST_WATCHER_SRCS) $(TEST_LZ4_SRCS) $(TEST_ZSTD_SRCS) $(TEST_ARTIFACT_SRCS) $(TEST_SQLITE_WRITER_SRCS) $(TEST_GO_LSP_SRCS) $(TEST_C_LSP_SRCS) $(TEST_PHP_LSP_SRCS) $(TEST_CS_LSP_SRCS) $(TEST_CS_LSP_BENCH_SRCS) $(TEST_SCOPE_SRCS) $(TEST_TYPE_REP_SRCS) $(TEST_PY_LSP_SRCS) $(TEST_PY_LSP_BENCH_SRCS) $(TEST_PY_LSP_STRESS_SRCS) $(TEST_PY_LSP_SCALE_SRCS) $(TEST_TS_LSP_SRCS) $(TEST_JAVA_LSP_SRCS) $(TEST_KOTLIN_LSP_SRCS) $(TEST_RUST_LSP_SRCS) $(TEST_TRACES_SRCS) $(TEST_CLI_SRCS) $(TEST_MEM_SRCS) $(TEST_UI_SRCS) $(TEST_HTTPD_SRCS) $(TEST_SECURITY_SRCS) $(TEST_YAML_SRCS) $(TEST_SIMHASH_SRCS) $(TEST_STACK_OVERFLOW_SRCS) $(TEST_INTEGRATION_SRCS)


# ── Build directories ────────────────────────────────────────────

BUILD_DIR = build/c

# ── Object file compilation (grammars need relaxed warnings) ─────

# Grammar + tree-sitter runtime: compiled without -Werror (upstream code has warnings)
GRAMMAR_OPT ?= -O2
GRAMMAR_OPT_TEST ?= -O1
GRAMMAR_CFLAGS = -std=c11 -D_DEFAULT_SOURCE $(GRAMMAR_OPT) -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) $(EXTRA_CFLAGS)
GRAMMAR_CFLAGS_TEST = -std=c11 -D_DEFAULT_SOURCE -g $(GRAMMAR_OPT_TEST) -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) \
	                      $(SANITIZE) $(EXTRA_CFLAGS)
GRAMMAR_CFLAGS_TEST_O0 = -std=c11 -D_DEFAULT_SOURCE -g -O0 -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) \
	                         $(SANITIZE) $(EXTRA_CFLAGS)
GRAMMAR_CFLAGS_TEST_NOSAN = -std=c11 -D_DEFAULT_SOURCE -g $(GRAMMAR_OPT_TEST) -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) \
	                            $(EXTRA_CFLAGS)
GRAMMAR_CFLAGS_TEST_NOSAN_O0 = -std=c11 -D_DEFAULT_SOURCE -g -O0 -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) \
	                               $(EXTRA_CFLAGS)
GRAMMAR_CFLAGS_TSAN = -std=c11 -D_DEFAULT_SOURCE -g $(GRAMMAR_OPT_TEST) -w -I$(CBM_DIR) -I$(TS_INCLUDE) -I$(TS_SRC) \
	                      -fsanitize=thread -fno-omit-frame-pointer $(EXTRA_CFLAGS)

# Object files for grammars + ts_runtime + LSP resolvers + preprocessor
GRAMMAR_OBJS_TEST = $(patsubst $(CBM_DIR)/%.c,$(BUILD_DIR)/%.o,$(GRAMMAR_SRCS))
TEST_GRAMMAR_FAST_O0 ?= 0
# Keep stack-sensitive parser families at -O1; global test-grammar -O0 regressed
# the nested Java/C#/Rust and front-end LSP stack guards.
TEST_GRAMMAR_O0_EXCLUDE ?= c c_sharp cpp java javascript rust tsx typescript
TEST_GRAMMAR_O0_NAMES ?= $(filter-out $(TEST_GRAMMAR_O0_EXCLUDE),$(patsubst grammar_%,%,$(basename $(notdir $(GRAMMAR_SRCS)))))
TEST_GRAMMAR_O0_OBJS = $(if $(filter 1 true TRUE yes YES on ON,$(TEST_GRAMMAR_FAST_O0)),$(addprefix $(BUILD_DIR)/grammar_,$(addsuffix .o,$(TEST_GRAMMAR_O0_NAMES))))
TS_RUNTIME_OBJ_TEST = $(BUILD_DIR)/ts_runtime.o
LSP_GENERATED_OBJ_TEST = $(patsubst $(CBM_DIR)/lsp/generated/%.c,$(BUILD_DIR)/lsp/generated/%.o,$(LSP_GENERATED_SRCS))
LSP_OBJ_TEST = $(patsubst $(CBM_DIR)/lsp/%.c,$(BUILD_DIR)/lsp/%.o,$(LSP_CORE_SRCS)) $(LSP_GENERATED_OBJ_TEST)
LSP_OBJ_PROD = $(patsubst $(CBM_DIR)/lsp/%.c,$(BUILD_DIR)/prod_lsp/%.o,$(LSP_SPLIT_SRCS))
PP_OBJ_TEST = $(BUILD_DIR)/preprocessor.o

$(TEST_GRAMMAR_O0_OBJS): GRAMMAR_CFLAGS_TEST = $(GRAMMAR_CFLAGS_TEST_O0)
$(LSP_GENERATED_OBJ_TEST): GRAMMAR_CFLAGS_TEST_NOSAN = $(GRAMMAR_CFLAGS_TEST_NOSAN_O0)

# ── Targets ──────────────────────────────────────────────────────

.PHONY: test test-artifacts test-repro test-foundation test-tsan cbm cbm-with-ui frontend embed clean-c lint lint-tidy lint-cppcheck lint-format security

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

# First-party object files. Grammars and selected vendored sources keep their
# specialized rules below; these rules split the project sources into parallel
# compilation units and emit depfiles for accurate warm rebuilds.
PROD_CORE_OBJS = $(patsubst %.c,$(BUILD_DIR)/prod/%.o,$(MAIN_SRC) $(CORE_SRCS))
TEST_CORE_OBJS = $(patsubst %.c,$(BUILD_DIR)/test/%.o,$(CORE_SRCS))
TEST_RUNNER_OBJS = $(patsubst %.c,$(BUILD_DIR)/test/%.o,$(ALL_TEST_SRCS)) $(TEST_CORE_OBJS)
TEST_REPRO_OBJS = $(patsubst %.c,$(BUILD_DIR)/test/%.o,$(TEST_REPRO_SRCS) $(CORE_SRCS))
TEST_FOUNDATION_OBJS = $(patsubst %.c,$(BUILD_DIR)/test/%.o,$(TEST_FOUNDATION_MAIN_SRC) $(TEST_FOUNDATION_SRCS) $(FOUNDATION_SRCS))
OBJ_DIRS = $(patsubst %/,%,$(sort $(dir $(PROD_CORE_OBJS) $(PROD_CORE_OBJS_WITH_ASSETS) $(TEST_RUNNER_OBJS) $(TEST_REPRO_OBJS) $(TEST_FOUNDATION_OBJS) $(LSP_OBJ_TEST) $(LSP_OBJ_PROD))))

VENDORED_DEP_OBJS = $(filter-out $(UNIXCODER_OBJ),$(OBJS_VENDORED_TEST) $(OBJS_VENDORED_PROD))

DEPFILES = $(PROD_CORE_OBJS:.o=.d) \
           $(PROD_CORE_OBJS_WITH_ASSETS:.o=.d) \
           $(TEST_RUNNER_OBJS:.o=.d) \
           $(TEST_REPRO_OBJS:.o=.d) \
           $(TEST_FOUNDATION_OBJS:.o=.d) \
           $(VENDORED_DEP_OBJS:.o=.d)

$(OBJ_DIRS):
	mkdir -p $@

.SECONDEXPANSION:

$(filter-out $(LSP_GENERATED_OBJ_TEST),$(LSP_OBJ_TEST)): | $(BUILD_DIR)/lsp/generated
$(LSP_OBJ_PROD): | $(BUILD_DIR)/prod_lsp/generated

$(BUILD_DIR)/prod/%.o: %.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(CFLAGS_PROD) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/test/%.o: %.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(CFLAGS_TEST) -Itests -MMD -MP -c -o $@ $<

$(BUILD_DIR)/test/vendored/yyjson/yyjson.o: $(YYJSON_SRC) | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(CFLAGS_COMMON) -g -O1 -Itests -MMD -MP -c -o $@ $<

# ── Foundation-only test (fast, no extraction) ───────────────────

$(BUILD_DIR)/test-foundation: $(TEST_FOUNDATION_OBJS) $(TS_RUNTIME_OBJ_TEST) $(BUILD_DIR)/mimalloc.o | $(BUILD_DIR)
	$(CC) $(CFLAGS_TEST) -o $@ $(TEST_FOUNDATION_OBJS) $(TS_RUNTIME_OBJ_TEST) $(BUILD_DIR)/mimalloc.o $(LDFLAGS_TEST)

test-foundation: $(BUILD_DIR)/test-foundation
	cd $(CURDIR) && $(BUILD_DIR)/test-foundation

# ── Grammar/TS/LSP object files (compiled with relaxed warnings) ─

$(BUILD_DIR)/%.o: $(CBM_DIR)/%.c | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/ts_runtime.o: $(CBM_DIR)/ts_runtime.c | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/lsp_all.o: $(LSP_UNITY_DEPS) | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST) $(SANITIZE) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/lsp/py_lsp.o: $(CBM_DIR)/lsp/py_lsp.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST) -DCBM_PYTHON_STDLIB_GENERATED -MMD -MP -c -o $@ $<

$(LSP_GENERATED_OBJ_TEST): $(BUILD_DIR)/lsp/generated/%.o: $(CBM_DIR)/lsp/generated/%.c | $(BUILD_DIR)/lsp/generated
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST_NOSAN) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/lsp/%.o: $(CBM_DIR)/lsp/%.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS_TEST) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/preprocessor.o: $(CBM_DIR)/preprocessor.cpp | $(BUILD_DIR)
	$(CXX_COMPILE) $(CXXFLAGS_TEST) -w -I$(CBM_DIR)/vendored -MMD -MP -c -o $@ $<

# ── Full test binary ─────────────────────────────────────────────

# mimalloc object files
MIMALLOC_OBJ_TEST = $(BUILD_DIR)/mimalloc.o
MIMALLOC_OBJ_PROD = $(BUILD_DIR)/prod_mimalloc.o

$(BUILD_DIR)/mimalloc.o: $(MIMALLOC_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(MIMALLOC_CFLAGS_TEST) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_mimalloc.o: $(MIMALLOC_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(MIMALLOC_CFLAGS) -MMD -MP -c -o $@ $<

# sqlite3 object files (vendored amalgamation)
SQLITE3_OBJ_TEST = $(BUILD_DIR)/sqlite3.o
SQLITE3_OBJ_PROD = $(BUILD_DIR)/prod_sqlite3.o

$(BUILD_DIR)/sqlite3.o: $(SQLITE3_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(SQLITE3_CFLAGS_TEST) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_sqlite3.o: $(SQLITE3_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(SQLITE3_CFLAGS) -MMD -MP -c -o $@ $<

# TRE regex (only compiled on Windows — POSIX uses system <regex.h>)
TRE_OBJ_TEST :=
TRE_OBJ_PROD :=
ifeq ($(IS_MINGW),yes)
TRE_OBJ_TEST = $(BUILD_DIR)/tre.o
TRE_OBJ_PROD = $(BUILD_DIR)/prod_tre.o

$(BUILD_DIR)/tre.o: $(TRE_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(TRE_CFLAGS) $(SANITIZE) -fno-sanitize=alignment -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_tre.o: $(TRE_SRC) | $(BUILD_DIR)
	$(CC_COMPILE) $(TRE_CFLAGS) -O2 -MMD -MP -c -o $@ $<
endif

# Vendored LZ4 (test build)
LZ4_OBJ_TEST = $(BUILD_DIR)/test_lz4.o $(BUILD_DIR)/test_lz4hc.o
$(BUILD_DIR)/test_lz4.o: $(CBM_DIR)/vendored/lz4/lz4.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -g -O1 $(SANITIZE) -w -I$(CBM_DIR) $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<
$(BUILD_DIR)/test_lz4hc.o: $(CBM_DIR)/vendored/lz4/lz4hc.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -g -O1 $(SANITIZE) -w -I$(CBM_DIR)/vendored/lz4 $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<

# Vendored zstd (test build)
ZSTD_OBJ_TEST = $(BUILD_DIR)/test_zstd.o
$(BUILD_DIR)/test_zstd.o: $(CBM_DIR)/vendored/zstd/zstd.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -g -O1 -w -I$(CBM_DIR)/vendored/zstd $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<

# nomic-embed-code pretrained vector blob
UNIXCODER_OBJ = $(BUILD_DIR)/unixcoder_blob.o
$(UNIXCODER_OBJ): $(UNIXCODER_BLOB_SRC) vendored/nomic/code_vectors.bin | $(BUILD_DIR)
	$(CC_COMPILE) -c -o $@ $<

OBJS_VENDORED_TEST = $(MIMALLOC_OBJ_TEST) $(SQLITE3_OBJ_TEST) $(TRE_OBJ_TEST) $(GRAMMAR_OBJS_TEST) $(TS_RUNTIME_OBJ_TEST) $(LSP_OBJ_TEST) $(PP_OBJ_TEST) $(LZ4_OBJ_TEST) $(ZSTD_OBJ_TEST) $(UNIXCODER_OBJ)

$(BUILD_DIR)/test/tests/test_c_lsp.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_cypher.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_extraction.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_java_lsp_coverage.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_php_lsp.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_pipeline.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_rust_lsp.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/tests/test_ts_lsp.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/src/mcp/mcp.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/test/src/semantic/semantic.o: CFLAGS_TEST = $(CFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/preprocessor.o: CXXFLAGS_TEST = $(CXXFLAGS_COMMON) -g -O0 $(SANITIZE)
$(BUILD_DIR)/sqlite3.o: SQLITE3_CFLAGS_TEST = -std=c11 -g -O0 -w -DSQLITE_DQS=0 -DSQLITE_THREADSAFE=1 -DSQLITE_ENABLE_FTS5 $(EXTRA_CFLAGS)

TEST_HEAVY_FIRST_OBJS = $(BUILD_DIR)/lsp/generated/go_stdlib_data.o $(BUILD_DIR)/test/src/semantic/semantic.o $(BUILD_DIR)/ts_runtime.o $(BUILD_DIR)/preprocessor.o $(BUILD_DIR)/test_lz4hc.o $(BUILD_DIR)/test_zstd.o $(BUILD_DIR)/test/tests/test_rust_lsp.o $(BUILD_DIR)/grammar_cobol.o $(BUILD_DIR)/grammar_lean.o $(BUILD_DIR)/lsp/generated/python_stdlib_data.o $(BUILD_DIR)/test/tests/test_pipeline.o $(BUILD_DIR)/test_lz4.o $(BUILD_DIR)/test/src/mcp/mcp.o $(BUILD_DIR)/grammar_systemverilog.o $(BUILD_DIR)/grammar_vim.o $(BUILD_DIR)/test/tests/test_java_lsp_coverage.o $(BUILD_DIR)/test/vendored/yyjson/yyjson.o $(BUILD_DIR)/grammar_fortran.o $(BUILD_DIR)/grammar_verilog.o $(BUILD_DIR)/grammar_blade.o $(BUILD_DIR)/test/tests/test_extraction.o $(BUILD_DIR)/test/tests/test_ts_lsp.o $(BUILD_DIR)/grammar_llvm.o $(BUILD_DIR)/grammar_sql.o $(BUILD_DIR)/test/tests/test_php_lsp.o $(BUILD_DIR)/lsp/generated/rust_stdlib_data.o $(BUILD_DIR)/grammar_ocaml.o $(BUILD_DIR)/grammar_cpp.o $(BUILD_DIR)/test/tests/test_cypher.o $(BUILD_DIR)/grammar_swift.o $(BUILD_DIR)/grammar_tlaplus.o $(BUILD_DIR)/test/src/cli/cli.o $(BUILD_DIR)/test/internal/cbm/extract_defs.o $(BUILD_DIR)/test/src/store/store.o $(BUILD_DIR)/grammar_fsharp.o $(BUILD_DIR)/test/tests/test_c_lsp.o $(BUILD_DIR)/sqlite3.o
TEST_RUNNER_OBJS_ORDERED = $(TEST_HEAVY_FIRST_OBJS) $(filter-out $(TEST_HEAVY_FIRST_OBJS),$(TEST_RUNNER_OBJS) $(OBJS_VENDORED_TEST))

$(BUILD_DIR)/test-runner: $(TEST_RUNNER_OBJS_ORDERED) | $(BUILD_DIR)
	$(CC) $(CFLAGS_TEST) -o $@ \
		$(TEST_RUNNER_OBJS_ORDERED) \
		$(LDFLAGS_TEST)

test: $(BUILD_DIR)/test-runner
	cd $(CURDIR) && $(BUILD_DIR)/test-runner

test-artifacts: $(BUILD_DIR)/test-runner $(BUILD_DIR)/codebase-memory-mcp

# ── Cumulative bug-reproduction runner (RED by design, non-gating) ──
# Mirrors test-runner's link line but uses repro_main.c (own main + counters)
# and TEST_REPRO_SRCS instead of ALL_TEST_SRCS. Exits non-zero while any bug is
# still reproduced (the expected state); bug-repro.yml surfaces it as a board.
$(BUILD_DIR)/test-repro-runner: $(TEST_REPRO_OBJS) $(OBJS_VENDORED_TEST) | $(BUILD_DIR)
	$(CC) $(CFLAGS_TEST) -Itests -o $@ \
		$(TEST_REPRO_OBJS) \
		$(OBJS_VENDORED_TEST) \
		$(LDFLAGS_TEST)

test-repro: $(BUILD_DIR)/test-repro-runner
	cd $(CURDIR) && $(BUILD_DIR)/test-repro-runner

# ── TSan full test ───────────────────────────────────────────────

test-tsan:
	@echo "TSan not yet wired for full extraction tests"

# ── Production binary ────────────────────────────────────────────

# Grammar/TS/LSP objects for production (compiled with relaxed warnings, -O2)
GRAMMAR_OBJS_PROD = $(patsubst $(CBM_DIR)/%.c,$(BUILD_DIR)/prod_%.o,$(GRAMMAR_SRCS))
TS_RUNTIME_OBJ_PROD = $(BUILD_DIR)/prod_ts_runtime.o
PP_OBJ_PROD = $(BUILD_DIR)/prod_preprocessor.o

$(BUILD_DIR)/prod_%.o: $(CBM_DIR)/%.c | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_ts_runtime.o: $(CBM_DIR)/ts_runtime.c | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_lsp_all.o: $(LSP_UNITY_DEPS) | $(BUILD_DIR)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_lsp/py_lsp.o: $(CBM_DIR)/lsp/py_lsp.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS) -DCBM_PYTHON_STDLIB_GENERATED -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_lsp/%.o: $(CBM_DIR)/lsp/%.c | $(BUILD_DIR) $$(dir $$@)
	$(CC_COMPILE) $(GRAMMAR_CFLAGS) -MMD -MP -c -o $@ $<

$(BUILD_DIR)/prod_preprocessor.o: $(CBM_DIR)/preprocessor.cpp | $(BUILD_DIR)
	$(CXX_COMPILE) $(CXXFLAGS_PROD) -w -I$(CBM_DIR)/vendored -MMD -MP -c -o $@ $<

# Vendored LZ4 (compiled separately, not unity-built via lz4_store.c)
LZ4_OBJ_PROD = $(BUILD_DIR)/prod_lz4.o $(BUILD_DIR)/prod_lz4hc.o
$(BUILD_DIR)/prod_lz4.o: $(CBM_DIR)/vendored/lz4/lz4.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -O2 -w -I$(CBM_DIR) $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<
$(BUILD_DIR)/prod_lz4hc.o: $(CBM_DIR)/vendored/lz4/lz4hc.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -O2 -w -I$(CBM_DIR)/vendored/lz4 $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<

# Vendored zstd (compiled separately, not unity-built via zstd_store.c)
ZSTD_OBJ_PROD = $(BUILD_DIR)/prod_zstd.o
$(BUILD_DIR)/prod_zstd.o: $(CBM_DIR)/vendored/zstd/zstd.c | $(BUILD_DIR)
	$(CC_COMPILE) -std=c11 -D_DEFAULT_SOURCE -O2 -w -I$(CBM_DIR)/vendored/zstd $(EXTRA_CFLAGS) -MMD -MP -c -o $@ $<

OBJS_VENDORED_PROD = $(MIMALLOC_OBJ_PROD) $(SQLITE3_OBJ_PROD) $(TRE_OBJ_PROD) $(GRAMMAR_OBJS_PROD) $(TS_RUNTIME_OBJ_PROD) $(LSP_OBJ_PROD) $(PP_OBJ_PROD) $(LZ4_OBJ_PROD) $(ZSTD_OBJ_PROD) $(UNIXCODER_OBJ)

PROD_HEAVY_FIRST_OBJS = $(BUILD_DIR)/prod_grammar_lean.o $(BUILD_DIR)/prod_grammar_systemverilog.o $(BUILD_DIR)/prod_grammar_verilog.o $(BUILD_DIR)/prod_grammar_cobol.o $(BUILD_DIR)/prod_preprocessor.o $(BUILD_DIR)/prod_lsp/generated/go_stdlib_data.o $(BUILD_DIR)/prod/vendored/yyjson/yyjson.o $(BUILD_DIR)/prod/src/mcp/mcp.o
PROD_OBJS_ORDERED = $(PROD_HEAVY_FIRST_OBJS) $(filter-out $(PROD_HEAVY_FIRST_OBJS),$(PROD_CORE_OBJS) $(OBJS_VENDORED_PROD))
PROD_UI_OBJS_ORDERED = $(PROD_HEAVY_FIRST_OBJS) $(filter-out $(PROD_HEAVY_FIRST_OBJS),$(PROD_CORE_OBJS_WITH_ASSETS) $(OBJS_VENDORED_PROD))

$(BUILD_DIR)/codebase-memory-mcp: $(PROD_OBJS_ORDERED) | $(BUILD_DIR)
	$(CC) $(CFLAGS_PROD) -o $@ \
		$(PROD_OBJS_ORDERED) \
		$(LDFLAGS)

cbm: $(BUILD_DIR)/codebase-memory-mcp
	@echo "Built: $(BUILD_DIR)/codebase-memory-mcp"

# ── Build with embedded UI (requires Node.js) ───────────────────

FRONTEND_DIR = graph-ui
FRONTEND_NODE_MODULES_STAMP = $(FRONTEND_DIR)/node_modules/.package-lock.stamp
FRONTEND_DIST_STAMP = $(FRONTEND_DIR)/.dist.stamp
FRONTEND_SRCS = $(shell find $(FRONTEND_DIR)/src $(FRONTEND_DIR)/@ -type f 2>/dev/null)
FRONTEND_DIST_FILES = $(shell find $(FRONTEND_DIR)/dist -type f ! -name '.*' 2>/dev/null)
FRONTEND_CONFIGS = $(FRONTEND_DIR)/package.json \
                   $(FRONTEND_DIR)/package-lock.json \
                   $(FRONTEND_DIR)/index.html \
                   $(FRONTEND_DIR)/tsconfig.json \
                   $(FRONTEND_DIR)/vite.config.ts

# Swap embedded_stub.c for the generated embedded_assets.c
UI_SRCS_WITH_ASSETS = $(subst src/ui/embedded_stub.c,src/ui/embedded_assets.c,$(UI_SRCS))
CORE_SRCS_WITH_ASSETS = $(subst src/ui/embedded_stub.c,src/ui/embedded_assets.c,$(CORE_SRCS))
PROD_CORE_OBJS_WITH_ASSETS = $(patsubst %.c,$(BUILD_DIR)/prod/%.o,$(MAIN_SRC) $(CORE_SRCS_WITH_ASSETS))

# Embedded asset object files (generated by embed script)
EMBED_OBJS = $(wildcard $(BUILD_DIR)/embedded/embed_*.o)
EMBED_STAMP = $(BUILD_DIR)/embedded/.stamp

$(FRONTEND_NODE_MODULES_STAMP): $(FRONTEND_DIR)/package.json $(FRONTEND_DIR)/package-lock.json
	cd $(FRONTEND_DIR) && npm ci
	touch $@

$(FRONTEND_DIST_STAMP): $(FRONTEND_NODE_MODULES_STAMP) $(FRONTEND_CONFIGS) $(FRONTEND_SRCS)
	cd $(FRONTEND_DIR) && { npm run build:typecheck & pid_typecheck=$$!; npm run build:bundle & pid_bundle=$$!; wait $$pid_typecheck; rc_typecheck=$$?; wait $$pid_bundle; rc_bundle=$$?; test $$rc_typecheck -eq 0 && test $$rc_bundle -eq 0; }
	touch $@

frontend: $(FRONTEND_DIST_STAMP)

$(EMBED_STAMP): $(FRONTEND_DIST_STAMP) $(FRONTEND_DIST_FILES) scripts/embed-frontend.sh | $(BUILD_DIR)
	scripts/embed-frontend.sh graph-ui/dist $(BUILD_DIR)/embedded
	touch $@

src/ui/embedded_assets.c: $(EMBED_STAMP)

embed: $(EMBED_STAMP)

cbm-with-ui: $(EMBED_STAMP) $(PROD_UI_OBJS_ORDERED)
	$(CC) $(CFLAGS_PROD) -o $(BUILD_DIR)/codebase-memory-mcp \
		$(PROD_UI_OBJS_ORDERED) \
		$(wildcard $(BUILD_DIR)/embedded/embed_*.o) \
		$(LDFLAGS)
	@echo "Built with UI: $(BUILD_DIR)/codebase-memory-mcp"

clean-c:
	rm -rf $(BUILD_DIR)

# ── Linting ─────────────────────────────────────────────────────

# clang-tidy and clang-format: use Homebrew LLVM on macOS, overridable via make args
# e.g. make lint-format CLANG_FORMAT=clang-format-18
LLVM_BIN = $(shell brew --prefix llvm 2>/dev/null)/bin
CLANG_TIDY ?= $(shell [ -x "$(LLVM_BIN)/clang-tidy" ] && echo "$(LLVM_BIN)/clang-tidy" || echo clang-tidy)
CLANG_FORMAT ?= $(shell [ -x "$(LLVM_BIN)/clang-format" ] && echo "$(LLVM_BIN)/clang-format" || echo clang-format)
CPPCHECK ?= cppcheck

# macOS SDK sysroot (needed for Homebrew LLVM to find system headers)
SYSROOT = $(shell xcrun --show-sdk-path 2>/dev/null)
SYSROOT_FLAG = $(if $(SYSROOT),-isysroot $(SYSROOT),)

# Our source files (excluding vendored, grammars, tree-sitter runtime)
LINT_SRCS = $(FOUNDATION_SRCS) $(STORE_SRCS) $(CYPHER_SRCS) $(MCP_SRCS) \
            $(DISCOVER_SRCS) $(GRAPH_BUFFER_SRCS) $(PIPELINE_SRCS) $(SIMHASH_SRCS) $(SEMANTIC_SRCS) \
            $(TRACES_SRCS) $(WATCHER_SRCS) $(CLI_SRCS) $(EXTRACTION_SRCS) $(AC_LZ4_SRCS) \
            $(ZSTD_SRCS) $(SQLITE_WRITER_SRC) $(MAIN_SRC)
LINT_HDRS = $(wildcard src/**/*.h src/*.h $(CBM_DIR)/*.h)
LINT_TEST_SRCS = $(ALL_TEST_SRCS)

# clang-tidy: deep static analysis (config in .clang-tidy)
lint-tidy:
	@echo "=== clang-tidy ==="
	@$(CLANG_TIDY) --quiet $(LINT_SRCS) -- $(CFLAGS_COMMON) $(SYSROOT_FLAG)

# cppcheck: complementary analysis (config in .cppcheck)
lint-cppcheck:
	@echo "=== cppcheck ==="
	@$(CPPCHECK) --enable=warning,style,performance,portability \
		--std=c11 --language=c \
		--suppressions-list=.cppcheck \
		--error-exitcode=1 \
		--inline-suppr \
		--quiet \
		--suppress=varFuncNullUB \
		--suppress=intToPointerCast \
		--suppress=unusedStructMember \
		--suppress=nullPointerOutOfMemory \
		--suppress=nullPointerArithmeticOutOfMemory \
		--suppress=ctunullpointerOutOfMemory \
		--suppress='nullPointer:internal/cbm/sqlite_writer.c' \
		-Isrc -Ivendored -Ivendored/sqlite3 \
		-I$(CBM_DIR) -I$(TS_INCLUDE) \
		$(LINT_SRCS)

# clang-format: formatting check (config in .clang-format, dry-run = no changes)
lint-format:
	@echo "=== clang-format ==="
	@$(CLANG_FORMAT) --dry-run --Werror $(LINT_SRCS) $(LINT_HDRS)

# Ban ALL NOLINT variants EXCEPT whitelisted NOLINT(misc-no-recursion).
# The whitelist is in src/foundation/recursion_whitelist.h with documented reasoning.
# Rule: NOLINT(misc-no-recursion) is allowed ONLY on function definitions that are
# listed in recursion_whitelist.h. All other NOLINT forms are banned.
lint-no-suppress:
	@echo "=== NOLINT check ==="
	@if grep -rn 'NOLINT' src/ internal/cbm/*.c internal/cbm/*.h 2>/dev/null \
		| grep -v vendored \
		| grep -v 'NOLINT(misc-no-recursion)' \
		| grep -v 'recursion_whitelist.h'; then \
		echo "ERROR: Banned NOLINT comment found in source code."; \
		echo "Only NOLINT(misc-no-recursion) is allowed, and only for whitelisted functions."; \
		echo "See src/foundation/recursion_whitelist.h for the whitelist."; \
		exit 1; \
	fi
	@echo "  Checking NOLINT(misc-no-recursion) against whitelist..."
	@scripts/check-nolint-whitelist.sh

# All linters (run with make -j lint for parallel execution)
lint: lint-tidy lint-cppcheck lint-format lint-no-suppress
	@echo "=== All linters passed ==="

# CI linters (no clang-tidy — platform-dependent, enforced locally via pre-commit)
lint-ci: lint-cppcheck lint-format lint-no-suppress
	@echo "=== CI linters passed ==="

# ── Security audit (6 layers) ────────────────────────────────────

# Run all security checks: static audit, binary strings, UI, install, network
# Requires: production binary already built (make cbm)
security: cbm
	@echo "=== Running security audit suite ==="
	scripts/security-audit.sh
	scripts/security-strings.sh $(BUILD_DIR)/codebase-memory-mcp
	scripts/security-ui.sh
	scripts/security-install.sh $(BUILD_DIR)/codebase-memory-mcp
	scripts/security-network.sh $(BUILD_DIR)/codebase-memory-mcp
	scripts/security-fuzz.sh $(BUILD_DIR)/codebase-memory-mcp
	scripts/security-vendored.sh
	@echo "=== All security checks passed ==="

-include $(DEPFILES)
